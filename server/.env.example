PORT=8000
USE_LLM=false
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
LLM_TIMEOUT_SECONDS=4
LLM_MAX_TOKENS=1800
LLM_MIN_ACCEPT_CONFIDENCE=0.55

# If the rule engine confidence is below this value, the LLM assist layer is called.
confidence=0.75

# One structured JSONL log file is created per /analyze-ticket request.
DEBUG_LOG_ENABLED=false
DEBUG_LOG_TO_CONSOLE=false
DEBUG_LOG_DIR=logs/requests
DEBUG_LOG_LLM_PROMPT=true
DEBUG_LOG_LLM_OUTPUT=true
